{
  "name": "upkyp-monorepo",
  "private": true,
  "version": "1.0.0",
  "scripts": {
    "dev": "turbo run dev",
    "dev:api": "turbo run dev --filter=@upkyp/api",
    "dev:landlord": "turbo run dev --filter=@upkyp/landlord",
    "dev:tenant": "turbo run dev --filter=@upkyp/tenant",
    "dev:admin": "turbo run dev --filter=@upkyp/admin",
    "build": "turbo run build",
    "build:api": "turbo run build --filter=@upkyp/api",
    "build:landlord": "turbo run build --filter=@upkyp/landlord",
    "build:tenant": "turbo run build --filter=@upkyp/tenant",
    "build:admin": "turbo run build --filter=@upkyp/admin",
    "start:api": "turbo run start --filter=@upkyp/api",
    "start:landlord": "turbo run start --filter=@upkyp/landlord",
    "start:tenant": "turbo run start --filter=@upkyp/tenant",
    "start:admin": "turbo run start --filter=@upkyp/admin",
    "lint": "turbo run lint",
    "type-check": "turbo run type-check",
    "clean": "turbo run clean && rm -rf node_modules",
    "format": "prettier --write \"**/*.{ts,tsx,md}\"",
    "chat": "node apps/chat-server/server.js"
  },
  "devDependencies": {
    "turbo": "^2.3.0",
    "prettier": "^3.4.2",
    "typescript": "^5.9.3"
  },
  "packageManager": "pnpm@9.15.0",
  "engines": {
    "node": ">=18.0.0"
  }
}
